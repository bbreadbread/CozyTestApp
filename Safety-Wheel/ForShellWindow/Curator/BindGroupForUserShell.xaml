<UserControl x:Class="Safety_Wheel.ForShellWindow.BindGroupForUser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Safety_Wheel.ForShellWindow"
             mc:Ignorable="d" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             Height="700" Width="875" >
    <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Привязка групп для пользователя ID ФИО" Grid.ColumnSpan="3" Style="{StaticResource ShellTitle}"/>

            <TextBlock Text="Все группы" Grid.Column="0" Grid.Row="1" Style="{StaticResource ShellMainText}"/>
            <ListView Grid.Row="2"
                      ItemsSource="{Binding service.InterestGroups}"
                      SelectedItem="{Binding current}" Width="400">
                
            </ListView>

            <Border BorderBrush="{StaticResource DarkViolet}" BorderThickness="5" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"/>

            <TextBlock Text="Группы пользователя" Grid.Column="2" Grid.Row="1" Style="{StaticResource ShellMainText}"/>
            <ListView Grid.Row="2"
                      Grid.Column="1"
                      ItemsSource="{Binding serviceUser.UserInterestGroups}"
                      SelectedItem="{Binding currentUser}" Width="400">
                
            </ListView>
        </Grid>
</UserControl>
