      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.ForShellWindow.Participant"
      mc:Ignorable="d" 
      d:DesignHeight="940" d:DesignWidth="1600">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="15*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Frame Source="../Pages/Participant/PartTest.xaml"/>

        <Button Grid.Column="0" Style="{StaticResource UpMenuButton}" VerticalAlignment="Top">
            <TextBlock Text="←"/>
        </Button>

        <DataGrid Grid.ColumnSpan="2" Grid.Row="2">
            
        </DataGrid>
    </Grid>
</UserControl>
