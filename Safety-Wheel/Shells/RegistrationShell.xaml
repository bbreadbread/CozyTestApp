<UserControl x:Class="CozyTest.ForShellWindow.RegistrationShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.ForShellWindow"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      mc:Ignorable="d" 
      Height="650" Width="750" Margin="60 0 62 55" >

    <StackPanel Orientation="Vertical">
        <TextBlock Text="Отправка заявки на регистрацию" Margin="20" Grid.ColumnSpan="3" Style="{StaticResource ShellTitle}"/>
        <Grid>
            <Grid.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}"/>
                <Style TargetType="PasswordBox" BasedOn="{StaticResource ShellPasswordBox}"/>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Имя Фамилия"/>
            <TextBox Grid.Row="2" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Логин"/>
            <PasswordBox Grid.Row="4" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Пароль"/>
            <PasswordBox Grid.Row="6" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Повтор пароля"/>

            <Button Grid.Row="8" Margin="0 0 0 0" Style="{StaticResource ShellButton}" Content="Отправить заявку"/>
        </Grid>
    </StackPanel>
</UserControl>
