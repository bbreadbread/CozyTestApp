<UserControl x:Class="CozyTest.ForShellWindow.RegistrationShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.ForShellWindow"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:view="clr-namespace:CozyTest.ViewModels.CuratorVM.AdministrationVM"
      mc:Ignorable="d" 
      Height="Auto" Width="750" Margin="100">


    <StackPanel Orientation="Vertical">
        <StackPanel.Resources>
            <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}">
                <Setter Property="Height" Value="90"/>
                <Setter Property="Margin" Value="0 15"/>
            </Style>
            <Style TargetType="PasswordBox" BasedOn="{StaticResource ShellPasswordBox}">
                <Setter Property="Height" Value="90"/>
                <Setter Property="Margin" Value="0 15"/>
            </Style>
        </StackPanel.Resources>
        <TextBox mah:TextBoxHelper.Watermark="Имя Фамилия" Text="{Binding Name}"/>
        <TextBox mah:TextBoxHelper.Watermark="Логин" Text="{Binding Login}"/>
        <PasswordBox mah:TextBoxHelper.Watermark="Пароль" x:Name="PasswordB"/>
        <PasswordBox mah:TextBoxHelper.Watermark="Повтор пароля" x:Name="RePasswordB"/>

        <Button Command="{Binding SendRequestCommand}" Click="Button_Click" Style="{StaticResource ShellButton}" Content="Отправить заявку" Margin=" 0 15" Height="90"/>
    </StackPanel>
</UserControl>
