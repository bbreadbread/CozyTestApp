<UserControl x:Class="CozyTest.Shells.Curator.PublicationDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CozyTest.Shells.Curator"
             mc:Ignorable="d" 
             Height="700" Width="875">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Опубликовать" Style="{StaticResource ShellMainText}"/>
            <RadioButton Content="Всем привязанным тестируемым и группам" Style="{StaticResource MahApps.Styles.RadioButton.Win10}"/>
            <RadioButton Content="Выбрать группы" Style="{StaticResource MahApps.Styles.RadioButton.Win10}"/>
            <RadioButton Content="Выбрать тестируемых" Style="{StaticResource MahApps.Styles.RadioButton.Win10}"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1">
            <DataGrid BorderThickness="0" ItemsSource="{Binding GroupsList}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Опубликовать">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsPublished, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                              Command="{Binding DataContext.ArchiveParticipantCommand, 
                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                              CommandParameter="{Binding}"
                              IsEnabled="False"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTextColumn Binding="{Binding Id}" Header="ID Группы"/>
                    <DataGridTextColumn Binding="{Binding Name}" Header="Название"/>
                    <DataGridTextColumn Binding="{Binding Count}" Header="Кол-во участников"/>

                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>
