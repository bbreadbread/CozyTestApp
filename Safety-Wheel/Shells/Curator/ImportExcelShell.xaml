<UserControl x:Class="CozyTest.ForShellWindow.ImportExcelShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.ForShellWindow"
      mc:Ignorable="d" 
     Height="570" Width="750" Margin="60 55">
    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="25"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="Тема теста: " VerticalAlignment="Center"/>
            <ComboBox Width="240" Style="{StaticResource UpMenuTestComboBox}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Тип: "/>
            <StackPanel Orientation="Vertical">
                <RadioButton Content="Тест" FontSize="24"/>
                <RadioButton Content="Опросник" FontSize="24"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Выберите файл для импорта:"/>
            <Button Grid.Row="1" Grid.Column="0" Content="Открыть проводник"  Style="{StaticResource ShellDarkSwampButton}" Height="50"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Выбранный файл:"/>
            <Button Grid.Row="1" Grid.Column="2" Content="Название" Style="{StaticResource SelectFileButton}" Height="50"/>
            <Border Grid.Row="2" Grid.Column="2" BorderBrush="Black" BorderThickness="2" VerticalAlignment="Top"/>
        </Grid>

        <WrapPanel Grid.Row="3" VerticalAlignment="Center">
            <TextBlock Text="Внимание! Убедитесь, что файл имеет вид файла из примера: "/>
            <Button Content="Скачать пример" Style="{StaticResource ShellDarkSwampButton}" Width="350" Height="50"/>
        </WrapPanel>

        <Button Grid.Row="4" Content="Проверка файла и импорт теста" Style="{StaticResource ShellDarkSwampButton}" Height="60"/>
        
    </Grid>
</UserControl>
