<UserControl x:Class="CozyTest.ForShellWindow.BindGroupForUser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CozyTest.ForShellWindow"
             mc:Ignorable="d" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:view="clr-namespace:CozyTest.ViewModels.CuratorVM.AdministrationVM"
             Height="700" Width="875"  Background="White">

    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Привязка групп для пользователя ID ФИО" Grid.ColumnSpan="3" Style="{StaticResource ShellTitle}"/>

        <TextBlock Text="Все группы" Grid.Column="0" Grid.Row="1" Style="{StaticResource ShellMainText}"/>
        <ListView Grid.Row="2"
                      ItemsSource="{Binding GroupsList}"
                      SelectedItem="{Binding CurrentGroup}" Width="400">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="Группа: "/>
                        <Run Text="{Binding Name}"/>
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border BorderBrush="{StaticResource DarkSwamp}" BorderThickness="5" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"/>
<!--SelectedItem="{Binding currentUser}" Width="400"-->
        <TextBlock Text="Группы пользователя" Grid.Column="2" Grid.Row="1" Style="{StaticResource ShellMainText}"/>
        <ListView Grid.Row="2"
                      Grid.Column="2"
                      ItemsSource="{Binding GroupsListCurrent}" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                            <TextBlock>
                                <Run Text="Группа: "/>
                                <Run Text="{Binding Name}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
