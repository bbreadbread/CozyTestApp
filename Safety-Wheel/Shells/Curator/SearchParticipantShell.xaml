<UserControl x:Class="CozyTest.ForShellWindow.SearchParticipantShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.ForShellWindow"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:view="clr-namespace:CozyTest.ViewModels.CuratorVM.AdministrationVM"
      mc:Ignorable="d" 
             Height="700" Width="1000"  Background="White">

    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}">
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Column="0" Grid.Row="0" Margin="5" mah:TextBoxHelper.Watermark="Поиск по имени" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <ComboBox Grid.Row="1" Height="70" Margin="5"  DisplayMemberPath="Name"  ItemsSource="{Binding CuratorsList}" SelectedItem="{Binding SelectedCuratorComboBox}" mah:TextBoxHelper.Watermark="Принадлежность к куратору" Style="{StaticResource UpMenuTestComboBox}"/>

        <ListView Grid.Row="3" ItemsSource="{Binding FilteredParticipantsList}" SelectedItem="{Binding SelectedParticipant}" Margin="10 0" MouseDoubleClick="ListView_Add">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                            <StackPanel.Resources>
                                <Style TargetType="Run">
                                    <Setter Property="FontSize" Value="19"/>
                                </Style>
                            </StackPanel.Resources>
                            <TextBlock>
                                <Run Text="ID "/>
                                <Run Text="{Binding Id}"  FontStyle="Italic"/>
                                <Run Text="  |  "/>
                                <Run Text="{Binding Name}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Создал: " FontStyle="Italic"/>
                                <Run Text="{Binding CuratorCreate.Name}"/>
                                <Run Text="  |  "/>
                                <Run Text="В архиве: " FontStyle="Italic"/>
                                <Run Text="{Binding IsArchive}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border BorderBrush="{StaticResource DarkSwamp}" BorderThickness="5" Grid.Row="1" Grid.RowSpan="3" Grid.Column="1"/>

        <TextBlock Text="Привязаны к Вам" Grid.Column="2" Grid.Row="0" Style="{StaticResource ShellMainText}"/>
        <ListView Grid.Row="1"
              Grid.RowSpan="2"
              Grid.Column="2"
              ItemsSource="{Binding ParticipantsCurrentList}"
              SelectedItem="{Binding SelectedCurrentParticipant}"  Margin="10 0"
              MouseDoubleClick="ListView_Remove">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                            <StackPanel.Resources>
                                <Style TargetType="Run">
                                    <Setter Property="FontSize" Value="19"/>
                                </Style>
                            </StackPanel.Resources>
                            <TextBlock>
                                <Run Text="ID "/>
                                <Run Text="{Binding Id}"  FontStyle="Italic"/>
                                <Run Text="  |  "/>
                                <Run Text="{Binding Name}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Создал: " FontStyle="Italic"/>
                                <Run Text="{Binding CuratorCreate.Name}"/>
                                <Run Text="  |  "/>
                                <Run Text="В архиве: " FontStyle="Italic"/>
                                <Run Text="{Binding IsArchive}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
