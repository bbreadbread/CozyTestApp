<UserControl x:Class="Safety_Wheel.ForShellWindow.ShellGradingSystem"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.ForShellWindow"
      mc:Ignorable="d" 
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      Height="610" Width="450">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="BorderBrush" Value="{StaticResource MainSwamp}"/>
                <Setter Property="BorderThickness" Value="0 0 0 2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>
        <TextBlock Text="Система оценивания для теста ПДД Тест А" Grid.Row="0" Style="{StaticResource ShellTitle}"/>
        <CheckBox Grid.Column="0" Grid.Row="1"
                  Content="Нужна система оценивания"
                  VerticalAlignment="Center"
                  FontSize="22"/>

        <StackPanel Grid.Column="0" Grid.Row="2">
            <StackPanel Orientation="Horizontal" Margin="0 25">
                 <CheckBox VerticalAlignment="Center"
                           FontSize="20"/>
                <TextBox Text="Отлично" Width="240"/>
                <TextBlock Text="—" Margin="15 0"/>
                <TextBox Text="75" Width="85"/>
                <TextBlock Text="%"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 25">
                <CheckBox VerticalAlignment="Center"
                          FontSize="20"/>
                <TextBox Text="Хорошо" Width="240"/>
                <TextBlock Text="—" Margin="15 0"/>
                <TextBox Text="60" Width="85"/>
                <TextBlock Text="%"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 25">
                <CheckBox VerticalAlignment="Center"
                          FontSize="20"/>
                <TextBox Text="Удовлетворительно" Width="240"/>
                <TextBlock Text="—" Margin="15 0"/>
                <TextBox Text="40" Width="85"/>
                <TextBlock Text="%"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"  Margin="0 25">
                <TextBlock Text="Все, что ниже: "/>
                <TextBox Text="Неудовлетворительно" Margin="30 0 0 0" Width="250"/>
            </StackPanel>
        </StackPanel>

        <Button Grid.Column="0" Grid.Row="4" Style="{StaticResource ShellButton}" Content="Сохранить"/>
    </Grid>
</UserControl>
