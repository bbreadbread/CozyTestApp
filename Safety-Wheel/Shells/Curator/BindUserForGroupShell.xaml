<UserControl x:Class="Safety_Wheel.ForShellWindow.BindUserForGroup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.ForShellWindow"
      mc:Ignorable="d" 
               xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
         Height="700" Width="875" >
    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}">
            </Style>
        </Grid.Resources>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Настройка привязки тестируемых к группе ID Название" Grid.ColumnSpan="3" Style="{StaticResource ShellTitle}"/>

        <TextBox Grid.Column="0" Grid.Row="1" Margin="5" mah:TextBoxHelper.Watermark="Поиск по имени"/>
        <ComboBox Grid.Row="2" Height="70" Margin="5" mah:TextBoxHelper.Watermark="Принадлежность к куратору" Style="{StaticResource UpMenuTestComboBox}"/>
        <ListView Grid.Row="3"
                  ItemsSource="{Binding service.InterestGroups}"
                  SelectedItem="{Binding current}" Width="400">
            
        </ListView>

        <Border BorderBrush="{StaticResource DarkSwamp}" BorderThickness="5" Grid.Row="1" Grid.RowSpan="3" Grid.Column="1"/>

        <TextBlock Text="Пользователи в группе" Grid.Column="2" Grid.Row="1" Style="{StaticResource ShellMainText}"/>
        <ListView Grid.Row="2"
                  Grid.RowSpan="2"
                  Grid.Column="1"
                  ItemsSource="{Binding serviceUser.UserInterestGroups}"
                  SelectedItem="{Binding currentUser}" Width="400">
           
        </ListView>
    </Grid>
</UserControl>
