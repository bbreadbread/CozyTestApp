<mah:MetroWindow x:Class="CozyTest.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:CozyTest"
        mc:Ignorable="d"
                 Height="630" Width="775"
        WindowTitleBrush="{StaticResource DarkSwamp}"
        GlowBrush="{StaticResource DarkSwamp}"
        BorderBrush="{StaticResource DarkSwamp}"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize">
    <Grid>
        <Viewbox Margin="30">
            <Frame x:Name="ShellGlobalFrame" NavigationUIVisibility="Hidden"/>
        </Viewbox>
    </Grid>
</mah:MetroWindow>
