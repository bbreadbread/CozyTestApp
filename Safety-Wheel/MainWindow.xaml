<Controls:MetroWindow x:Class="Safety_Wheel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Safety_Wheel"
        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Cozy Test" 
        WindowState="Maximized"
        WindowTitleBrush="{StaticResource DarkSwamp}"
        GlowBrush="{StaticResource DarkSwamp}"
        BorderBrush="{StaticResource DarkSwamp}"
        Closing="MainWindow_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="54*"/>
            <ColumnDefinition Width="91*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border 
                Background="#FFD9D9D9"
                VerticalAlignment="Center"
                Height="80" Grid.ColumnSpan="2">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Foreground="{StaticResource MainSwamp}"
                           FontSize="48"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="80,0,0,0"
                           Text="{Binding UserFullName}"/>

                <StackPanel Grid.Column="1" 
                            Height="80"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Background="{StaticResource DarkSwamp}">

                    <Image Source="pack://application:,,,/Images/back_logo.png"
                           Width="60" 
                           Height="60"
                           Margin="30,0,15,0"
                           Cursor="Hand">
                        <Image.InputBindings>
                            <MouseBinding Gesture="LeftClick" Command="{Binding GoBackCommand}"/>
                        </Image.InputBindings>
                    </Image>

                    <Image Source="pack://application:,,,/Images/exit_logo.png"
                           Width="60" 
                           Height="60"
                           Cursor="Hand"
                           Margin="15,0,30,0">
                        <Image.InputBindings>
                            <MouseBinding Gesture="LeftClick" Command="{Binding ExitCommand}"/>
                        </Image.InputBindings>
                    </Image>

                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" 
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Source="Pages/AuthorizationPage.xaml" Grid.ColumnSpan="2"/>
    </Grid>
</Controls:MetroWindow>