<UserControl x:Class="CozyTest.Pages.Curator.CuratorCreateTestsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:vm="clr-namespace:CozyTest.ViewModels.CreateTestsVM"
             xmlns:conv="clr-namespace:CozyTest.Converters">

    <UserControl.Resources>
        <conv:IndexPlusOneConverter x:Key="IndexPlusOneConverter"/>
        <conv:NullImageConverter x:Key="NullImageConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        
        <conv:EmptyCollectionToVisibilityConverter x:Key="EmptyToVisible" EmptyValue="Visible" NotEmptyValue="Collapsed"/>
        <conv:EmptyCollectionToVisibilityConverter x:Key="EmptyToCollapsed" EmptyValue="Collapsed" NotEmptyValue="Visible"/>
        <conv:BoolToIntConverter x:Key="BoolToIntConverter"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisible" 
                                ZeroValue="Visible" 
                                NonZeroValue="Collapsed"/>

        <conv:ZeroToVisibilityConverter x:Key="ZeroToCollapsed" 
                                ZeroValue="Collapsed" 
                                NonZeroValue="Visible"/>
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLength" TrueValue="Auto" FalseValue="0"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Expander BorderBrush="{StaticResource MainSwamp}" BorderThickness="2" Background="{StaticResource LightSwamp}" Foreground="{StaticResource DarkSwamp}" TextElement.FontWeight="SemiBold" IsExpanded="False">
            <Expander.Header>
                <TextBlock Text="Подробности" HorizontalAlignment="Center" FontSize="25"/>
            </Expander.Header>
            <Grid Grid.Row="0" MaxWidth="1450" Margin="0 10 0 10" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource UpMenuTest}" Grid.Row="0" Grid.Column="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Column="0" 
                     Margin="1 1 5 2" 
                     Background="{StaticResource LightSwamp}" 
                     BorderThickness="0"
                     mah:TextBoxHelper.Watermark="Минут"/>
                        <Border Background="{StaticResource DarkSwamp}" Grid.Row="1" Margin="10 0"/>
                        <TextBlock Grid.Column="1" 
                       Text="мин." 
                       Grid.RowSpan="3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextElement.FontSize="16"
                       TextElement.Foreground="{StaticResource MainSwamp}"/>
                    </Grid>
                </Border>

                <TextBox Grid.Row="0" 
                         Grid.Column="1" 
                         Grid.ColumnSpan="2" 
                         Text="{Binding Test.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{DynamicResource TBoxStyle}" 
                         mah:TextBoxHelper.Watermark="Название теста"
                         Height="45"
                         Margin="15 0 15 0"/>

                            <ComboBox Style="{StaticResource UpMenuTestComboBox}"  
                          ItemsSource="{Binding Topics}"
                          SelectedItem="{Binding SelectedTopic}" 
                          DisplayMemberPath="Name"
                          Grid.Row="0" 
                          Grid.Column="3" 
                          mah:TextBoxHelper.Watermark="Тема"
                          Height="45"/>

                            <ComboBox Style="{StaticResource UpMenuTestComboBox}" 
                          Grid.Row="0" 
                          Grid.Column="4" 
                          mah:TextBoxHelper.Watermark="Тип"
                          Height="45"
                          Margin="10 0 0 0"/>

                <mah:NumericUpDown Grid.Row="1" 
                   Grid.Column="0"
                   Height="45"
                   Margin="0 10 0 0"
                   mah:TextBoxHelper.Watermark="Без ограничений"
                   Minimum="0"
                   Maximum="100"
                   Interval="1"
                   Value="{Binding MaxAttemptsPerPerson}"
                   Style="{StaticResource UpMenuTestNumericUpDown}"/>

                <TextBox Grid.Row="1" 
                         Grid.Column="1" 
                         Grid.ColumnSpan="2"
                         Height="45" 
                         Margin="15 10 15 0"
                         mah:TextBoxHelper.Watermark="Описание" 
                         Style="{DynamicResource TBoxStyle}" 
                         Background="{StaticResource LightSwamp}" 
                         BorderBrush="{StaticResource MainSwamp}"
                         BorderThickness="3"
                         Text="{Binding Test.Description, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Style="{StaticResource ShellDarkSwampButton}" 
                        Grid.Row="1" 
                        Grid.Column="3"
                        Height="45"
                        Margin="0 10 0 0">
                    <Button.Content>
                        <TextBlock TextWrapping="Wrap" 
                                   Text="Соавторство" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   TextElement.Foreground="{StaticResource White}"
                                   TextElement.FontSize="18"/>
                    </Button.Content>
                </Button>

                <Button Style="{StaticResource ShellDarkSwampButton}" 
                        Grid.Row="1" 
                        Grid.Column="4"
                        Height="45"
                        Margin="10 10 0 0">
                    <Button.Content>
                        <TextBlock TextWrapping="Wrap" 
                       Text="Система оценивания" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       TextElement.Foreground="{StaticResource White}"
                       TextElement.FontSize="18"/>
                    </Button.Content>
                </Button>
            </Grid>
        </Expander>

        <Grid Grid.Row="1" Width="1100">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" 
                          MaxHeight="1000">
                <StackPanel Margin="20">

                    <ItemsControl ItemsSource="{Binding Questions}"
                                  AlternationCount="500">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0 10"
                                        Padding="15"
                                        Style="{StaticResource CardQuestsBorderStyle}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        Background="{StaticResource White}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" 
                                                    Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal" 
                                                    Margin="0 0 0 10">
                                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                                      Path=(ItemsControl.AlternationIndex),
                                                                      Converter={StaticResource IndexPlusOneConverter}}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource DarkSwamp}"/>

                                            <Button Content="✕"
                                                    Style="{StaticResource CuratorCreateTestsButton}"
                                                    Command="{Binding DataContext.RemoveQuestionCommand, 
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="10 0 0 0"/>
                                            
                                            
                                        </StackPanel>

                                        <TextBox Grid.Row="1" 
                                                 Grid.ColumnSpan="2"
                                                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource TBoxStyle}"
                                                 mah:TextBoxHelper.Watermark="Текст вопроса"
                                                 Margin="0 0 0 15"/>

                                        <Grid Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center">
                                            <ItemsControl ItemsSource="{Binding Options}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource CardQuestsBorderStyle}"
                                                                Margin="15"
                                                                Width="230"
                                                                Height="230">
                                                            <Grid>
                                                                <Grid Visibility="{Binding IsImage, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="4*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                             mah:TextBoxHelper.Watermark="Текст ответа"
                                                                             Style="{StaticResource TBoxStyle}"/>

                                                                    <Grid Grid.Row="1">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <CheckBox Content="Правильный" 
                                                                                  IsChecked="{Binding IsCorrect}"
                                                                                  Margin="2 0"
                                                                                  HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"/>

                                                                        <Button Grid.Column="1"
                                                                                Content="✕" 
                                                                                Padding="0" 
                                                                                Style="{StaticResource CuratorCreateTestsButton}"
                                                                                Command="{Binding DeleteCommand}"
                                                                                HorizontalAlignment="Right"
                                                                                VerticalAlignment="Center"
                                                                                Width="30"
                                                                                Height="30"/>
                                                                    </Grid>
                                                                </Grid>

                                                                <Grid Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="4*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>

                                                                    <Grid>
                                                                        <Image Source="{Binding AbsoluteImagePath, Converter={StaticResource NullImageConverter}}"
                                                                               VerticalAlignment="Stretch"
                                                                               HorizontalAlignment="Stretch"
                                                                               Stretch="UniformToFill">
                                                                        </Image>
                                                                    </Grid>

                                                                    <Grid Grid.Row="1">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <CheckBox Content="Правильный" 
                                                                                  IsChecked="{Binding IsCorrect}"
                                                                                  HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="2 0"/>

                                                                        <StackPanel Grid.Column="1" 
                                                                                    Orientation="Horizontal"
                                                                                    HorizontalAlignment="Right">
                                                                            <Button Content="✕" 
                                                                                    Padding="0"
                                                                                    Style="{StaticResource CuratorCreateTestsButton}"
                                                                                    Command="{Binding DeleteCommand}"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Width="30"
                                                                                    Height="30"
                                                                                    Margin="0 0 5 0"/>

                                                                            <Button Content="🔍" 
                                                                                    Padding="0"
                                                                                    Style="{StaticResource CuratorCreateTestsButton}"
                                                                                    Command="{Binding ShowFullScreenImageCommand}"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Width="30"
                                                                                    Height="30"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>

                                        <!-- ПРАВАЯ ЧАСТЬ: Основное изображение вопроса -->
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Основное изображение:" 
                                                           Style="{StaticResource Hint}" 
                                                           Margin="0" 
                                                           TextWrapping="Wrap"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"/>

                                                <StackPanel Grid.Column="1" 
                                                            HorizontalAlignment="Right" 
                                                            Orientation="Horizontal">
                                                    <Button Content="✕" 
                                                            Padding="0" 
                                                            Margin="0 0 5 0"
                                                            Style="{StaticResource CuratorCreateTestsButton}"
                                                            Command="{Binding DeleteMainImageCommand}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Width="30"
                                                            Height="30"/>
                                                    <Button Content="🔍" 
                                                            Padding="0" 
                                                            Margin="0 0 5 0"
                                                            Style="{StaticResource CuratorCreateTestsButton}"
                                                            Command="{Binding ShowFullScreenImageCommand}"
                                                            Visibility="{Binding PreviewImagePath, Converter={StaticResource StringToVisibility}}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Width="30"
                                                            Height="30"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border Style="{StaticResource BackgroundDarkSwamp}"
                                                    BorderBrush="Gray" 
                                                    BorderThickness="2" 
                                                    CornerRadius="4" 
                                                    Margin="0" 
                                                    Padding="0">

                                                <Button Tag="{Binding}"
                                                        Command="{Binding SetQuestionImageCommand}"
                                                        Background="Transparent"
                                                        BorderThickness="0" 
                                                        Width="200" 
                                                        Height="200" 
                                                        Margin="0" 
                                                        Padding="0">
                                                    <Image Stretch="UniformToFill" Margin="0">
                                                        <Image.Source>
                                                            <PriorityBinding>
                                                                <Binding Path="PreviewImagePath" 
                                                                         Converter="{StaticResource NullImageConverter}"/>
                                                                <Binding Source="pack://application:,,,/Images/add_picture_icon_2.png"/>
                                                            </PriorityBinding>
                                                        </Image.Source>
                                                    </Image>
                                                </Button>
                                            </Border>

                                            <StackPanel Orientation="Vertical" 
                                                        HorizontalAlignment="Center"
                                                        Margin="0 10 0 0">

                                                <Button Content="+ Текст"
                                                        Command="{Binding AddTextOptionCommand}"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource ConfirmButton}"
                                                        Width="200"/>
                                                <Button Content="+ Фото"
                                                        Command="{Binding AddImageOptionCommand}"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource ConfirmButton}"
                                                        Width="200"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Expander Grid.Row="3" 
                                                  Grid.ColumnSpan="2"
                                                  Margin="0 15 0 0" Background="{StaticResource DarkSwamp}" >
                                            <Expander.Header>
                                                <TextBlock Text="Комментарий" HorizontalAlignment="Left" FontSize="25" Foreground="White" FontWeight="DemiBold"/>
                                            </Expander.Header>

                                            <Border Background="{StaticResource LightSwamp}">
                                                <TextBox Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         Height="80"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         mah:TextBoxHelper.Watermark="Введите комментарий к вопросу..."/>
                                            </Border>
                                        </Expander>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Добавить вопрос"
                            Command="{Binding AddQuestionCommand}"
                            Style="{StaticResource ConfirmButton}"
                            HorizontalAlignment="Center"
                            Margin="0 0 0 20"/>
                    <Button Content="СОХРАНИТЬ ТЕСТ"
                            Margin="0 20"
                            Command="{Binding SaveTestCommand}"
                            Style="{StaticResource DownButton}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>