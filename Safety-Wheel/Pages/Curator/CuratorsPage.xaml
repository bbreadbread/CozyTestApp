<UserControl x:Class="CozyTest.Pages.Curator.CuratorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.Pages.Curator"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:DesignHeight="915" d:DesignWidth="1815"         
             xmlns:vm="clr-namespace:CozyTest.ViewModels.CuratorVM.AdministrationVM">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Margin="15" LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                <ToggleButton Width="Auto" Height="40" Margin="10" Content="Активные" IsChecked="{Binding ActiveIsChecked}"/>
                <ToggleButton Width="Auto" Height="40" Margin="10" Content="Архивные" IsChecked="{Binding ArchiveIsChecked}"/>
                <TextBox Width="270" Height="42" Margin="20 10" mah:TextBoxHelper.Watermark="Поиск по имени" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Expander Header="Кураторы" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Button Style="{StaticResource PaleButton}" Command="{Binding AddCuratorCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/Images/plus_icon.png"/>
                                <TextBlock Text="Создать нового экзаменатора" VerticalAlignment="Center" Margin="10 0" FontSize="20"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <DataGrid Grid.Row="1"
                      BorderThickness="3" 
                      BorderBrush="{StaticResource MainSwamp}"
                      ItemsSource="{Binding CuratorsList}" 
                      SelectedItem="{Binding SelectedCurator}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HeadersVisibility="Column"
                              Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                            <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                            <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                            <DataGridTemplateColumn Header="Админ">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsAdmin, Mode=OneWay}" IsEnabled="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="В архиве">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay}" IsEnabled="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding EditCuratorCommand}" Header="Редактировать"/>
                                <MenuItem Command="{Binding ArchiveCuratorCommand}" Header="В архив"/>
                                <MenuItem Command="{Binding AdminStatusCuratorCommand}" Header="Изменить статус админа"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </Expander>
        </DockPanel>

        <Grid Grid.Column="2" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
               Style="{StaticResource MainText}" 
               Text="{Binding SelectedCurator.Name, StringFormat='Данные, связанные с экзаменатором {0}'}"/>

            <TabControl Grid.Row="1">
                <TabItem Header="Связанные тестируемые">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                          BorderThickness="3"                                       
                          ItemsSource="{Binding ParticipantsForCuratorList}"  
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          BorderBrush="{StaticResource MainSwamp}"  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                                <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                <DataGridTemplateColumn Header="В архиве">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay}" IsEnabled="False"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Связанные тесты">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                          BorderThickness="3" 
                          ItemsSource="{Binding TestsForCuratorList}"  
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          BorderBrush="{StaticResource MainSwamp}"  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Topic.Name}" Header="Тема" />
                                <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                <DataGridTextColumn Binding="{Binding DateOfCreating}" Header="Дата создания" />
                                <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                <DataGridTextColumn Binding="{Binding MaxNumPassing}" Header="Макс. попыток" />
                                <DataGridTemplateColumn Header="В архиве">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay}" IsEnabled="False"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding ArchiveTestCommand}" Header="В архив"/>
                                    <MenuItem Command="{Binding PublishTestCommand}" Header="Настройки публикации"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Связанные группы">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                          BorderThickness="3" 
                          ItemsSource="{Binding GroupsForCuratorList}"  
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          BorderBrush="{StaticResource MainSwamp}"  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                <DataGridTextColumn Binding="{Binding CuratorId}" Header="Создатель ID" />
                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>