<Page x:Class="Safety_Wheel.Pages.Curator.CuratorWelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.Pages.Curator"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      d:DesignHeight="850" d:DesignWidth="1200"
      Title="CuratorWelcomePage"
      Loaded="Page_Loaded">
    
    <Viewbox>
        <Grid Background="White">
            <Grid x:Name="AttemptsWelcome" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Source="pack://application:,,,/Images/first_arrow_icon.png" VerticalAlignment="Bottom"/>

                <StackPanel Grid.ColumnSpan="3" Grid.Row="1" Orientation ="Vertical">
                    <TextBlock Style="{StaticResource MainWelcomeTB}" Text="Для начала работы выберите ученика и дату из левого меню" Foreground="{StaticResource DarkViolet}" FontWeight="Bold"/>
                    <TextBlock Style="{StaticResource MainWelcomeTB}" Text="Далее выберите конкретное прохождение из таблицы ниже"/>
                </StackPanel>

                <Image Grid.Column="1" Grid.Row="2" Source="pack://application:,,,/Images/second_arrow_icon.png" HorizontalAlignment="Right"/>
            </Grid>

            <Grid x:Name="GeneralWelcome">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="3" Grid.Row="0" Style="{StaticResource MainWelcomeTB}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource DarkViolet}" Text="Добро пожаловать на панель куратора"  Margin="35"/>
                <TextBlock Grid.ColumnSpan="3" Grid.Row="1" Style="{StaticResource MainWelcomeTB}" FontSize="25" Text="Здесь можно следить и управлять процессом тестирования."/>
                <TextBlock Grid.ColumnSpan="3" Grid.Row="2" Style="{StaticResource MainWelcomeTB}" FontSize="25" Text="Создавайте тесты, следите за успеваемостью и получайте аналитику результатов."/>
                <TextBlock Grid.ColumnSpan="3" Grid.Row="3" Style="{StaticResource MainWelcomeTB}" FontSize="32" Text="Все инструменты для контроля за тестированием собраны в одном месте" Margin="35"/>

                <Border Grid.Column="0" Grid.Row="4"  Style="{StaticResource GeneralWelcome50r}" MouseLeftButtonDown="GoTest_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Welcome30r}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Row="1" Grid.Column="0" Source="pack://application:,,,/Images/test_icon.png" Width="50" Height="50"  Margin="10"/>
                                <Label Grid.Column="1" Content="Тесты" Style="{StaticResource WelcomeLabel}"/>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="2*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource WelcomeTxt}" Text="В данном разделе собраны все тесты, созданные вами ранее."/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource WelcomeTxt}" Text="Нажмите на любой из них, чтобы внести изменения, или создайте новый, воспользовавшись панелью с кнопкой «+»" Margin="18 18 0 18"/>
                            <Image Grid.Row="1" Grid.Column="1" Source="pack://application:,,,/Images/plus_icon.png" Width="70" Height="70"  Margin="0 10 10 10"/>
                       
                        </Grid>
                    </Grid>
                </Border>
                
                <Border Grid.Column="1" Grid.Row="4" Style="{StaticResource GeneralWelcome50r}" MouseLeftButtonDown="GoResult_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Welcome30r}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Row="1" Grid.Column="0" Source="pack://application:,,,/Images/result_icon.png" Width="50" Height="50"  Margin="10"/>
                                <Label Grid.Column="1" Content="Результаты" Style="{StaticResource WelcomeLabel}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource WelcomeTxt}" Text="В этом разделе вы можете просмотреть детализацию прохождений тестов вашими учениками."/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource WelcomeTxt}" Text="Для удобства отслеживания воспользуйтесь сортировкой по месяцам" Margin="18 18 0 18"/>
                            <Image Grid.Row="1" Grid.Column="1" Source="pack://application:,,,/Images/sort_icon.png" Width="70" Height="70"  Margin="0 10 10 10"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Grid.Row="4" Style="{StaticResource GeneralWelcome50r}"  MouseLeftButtonDown="GoStatistic_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Welcome30r}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Row="1" Grid.Column="0" Source="pack://application:,,,/Images/statistic_icon.png" Width="50" Height="50"  Margin="10"/>
                                <Label Grid.Column="1" Content="Статистика" Style="{StaticResource WelcomeLabel}"/>
                            
                            </Grid>
                        </Border>
                        
                        <TextBlock Grid.Row="1" Style="{StaticResource WelcomeTxt}" Text="Здесь вы можете посмотреть результаты тестирования в виде статистики. Она помогает оценить успеваемость учеников и увидеть, как в среднем они отвечают на тесты. Эти данные помогут скорректировать обучение и добиться лучших результатов."/>
                    
                    </Grid>
                </Border>

                <Border Style="{StaticResource Welcome30r}" Grid.ColumnSpan="3" Grid.Row="5" Margin="20 20 20 60"  MouseLeftButtonDown="GoSetting_Click">
                    <Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Row="1" Grid.Column="0" Source="pack://application:,,,/Images/settings_icon.png" Width="50" Height="50"  Margin="10"/>
                            <Label Grid.Column="0" Grid.ColumnSpan="2" Content="Управление" Style="{StaticResource WelcomeLabel}" HorizontalAlignment="Center"/>
                        
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</Page>
