<UserControl x:Class="Safety_Wheel.Pages.Curator.SelectionTape"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.Pages.Curator"
      mc:Ignorable="d" 
      d:DesignHeight="45" HorizontalAlignment="Stretch">
    <Grid Background="{StaticResource LightViolet}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Style="{StaticResource UpMenuButton}">
            <TextBlock Text="←"/>
        </Button>

        <Button Grid.Column="1" Style="{StaticResource UpMenuButton}">
            <TextBlock Text="Лента"/>
        </Button>

        <Button Grid.Column="2" Style="{StaticResource UpMenuButton}">
            <TextBlock Text="Карточки"/>
        </Button>

        <Button Grid.Column="3" Style="{StaticResource UpMenuButton}">
            <TextBlock Text="Конструктор"/>
        </Button>
    </Grid>
</UserControl>
