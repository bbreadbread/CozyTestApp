<UserControl x:Class="CozyTest.Pages.Curator.CuratorAllTests"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:CozyTest.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:CardWidthConverter x:Key="CardWidthConverter"/>
        <conv:CardMarginConverter x:Key="CardMarginConverter"/>
        <conv:BoolToTextConverter x:Key="ArchiveTextConverter" 
                           TrueText="В АРХИВЕ" 
                           FalseText=" "/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" MaxWidth="1450" Margin="0 20 0 20" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <RadioButton Grid.Row="0" Grid.Column="0" 
                      Content="Своё авторство" 
                      VerticalAlignment="Center" 
                      Margin="20 0 0 0"
                      IsChecked="{Binding IsOwnAuthorship}" TextElement.FontSize="20" TextElement.Foreground="{StaticResource MainSwamp}" TextElement.FontWeight="Bold"
                         GroupName="123"/>

            <StackPanel Grid.Row="0" Grid.Column="1" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="20 0 20 0">
                <RadioButton Content="Авторство: " 
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsNotMyAuthorship}"  TextElement.FontSize="20" TextElement.Foreground="{StaticResource MainSwamp}" TextElement.FontWeight="Bold"
                              GroupName="123"/>
                <ComboBox Height="45" 
                          Width="300" 
                          Style="{StaticResource UpMenuTestComboBox}"
                          mah:TextBoxHelper.Watermark="Выберите автора" 
                          ItemsSource="{Binding Curators}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedCoauthor}"
                          IsEnabled="{Binding IsNotMyAuthorship}"/>
            </StackPanel>

            <ComboBox Height="45" 
                      Grid.Row="0" 
                      Grid.Column="2"  
                      mah:TextBoxHelper.Watermark="Тема" 
                      Style="{StaticResource UpMenuTestComboBox}"
                      ItemsSource="{Binding Topics}"
                      DisplayMemberPath="Name"
                      
                      SelectedItem="{Binding SelectedTopic}"/>

            <Button Grid.Row="0" 
                    Grid.Column="4"
                    Width="130"
                    Height="50"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="3"
                    HorizontalAlignment="Center"
                    Command="{Binding ClearFiltersCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Images/plus_icon.png"
                       Width="40"
                       Height="40"/>
                    <TextBlock Text="Создать тему" TextWrapping="Wrap" Width="80" Margin="10 0 0 0" TextElement.Foreground="{StaticResource MainSwamp}" TextElement.FontWeight="Bold"/>
                </StackPanel>

            </Button>

            <Button Grid.Row="0" 
                    Grid.Column="3"
                    Width="120"
                    Height="50"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="3"
                    HorizontalAlignment="Right"
                    Command="{Binding ClearFiltersCommand}">

                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Images/clear_icon.png"
                           Width="40"
                           Height="40"/>
                    <TextBlock Text="Очистить фильтры" TextWrapping="Wrap" Width="80" Margin="10 0 0 0" TextElement.Foreground="{StaticResource MainSwamp}" TextElement.FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <DatePicker Height="45" 
                        Grid.Row="1" 
                        Grid.Column="0" 
                        Margin="20 0 0 0"
                        SelectedDate="{Binding SelectedDate}"/>

            <TextBox Height="45" 
                     Grid.Row="1" 
                     Grid.Column="1" 
                     mah:TextBoxHelper.Watermark="Введите название теста" 
                     Background="{StaticResource LightSwamp}" 
                     BorderBrush="{StaticResource MainSwamp}"
                     BorderThickness="3" 
                     Margin="20 0 20 0"
                     Text="{Binding TestNameFilter, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Grid.Row="1" Grid.Column="2">
                <ToggleButton Content="Архивные" 
                  TextElement.FontSize="20" 
                  IsChecked="{Binding IsSelectedArchive}" 
                  TextElement.FontWeight="Bold" 
                  Margin="0 0 0 5"/>

                <ToggleButton Content="Активные"
                  TextElement.FontSize="20" 
                  IsChecked="{Binding IsSelectedActive}" 
                  TextElement.FontWeight="Bold"/>
            </StackPanel>

            <ComboBox Height="45" 
                      Grid.Row="1" 
                      Grid.Column="3" 
                      Grid.ColumnSpan="2" 
                      mah:TextBoxHelper.Watermark="Соавтор" 
                      Style="{StaticResource UpMenuTestComboBox}"
                      ItemsSource="{Binding Curators}"
                      DisplayMemberPath="Name"
                      Margin="20 0 0 0"
                      SelectedItem="{Binding SelectedCoauthor}"/>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer Grid.Row="0" 
               VerticalScrollBarVisibility="Hidden"
              HorizontalScrollBarVisibility="Disabled" MaxHeight="1000" MaxWidth="1400">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Tests}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Width="{Binding Converter={StaticResource CardWidthConverter}}"
                                        Margin="{Binding Converter={StaticResource CardMarginConverter}}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction Command="{Binding DataContext.CardClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>

                                    <Grid>
                                        <Grid Visibility="{Binding IsCreateCard, Converter={StaticResource BoolToVisibility}}">
                                            <Border BorderThickness="2" 
                                                  Background="{StaticResource lightTurquoise}"
                                                  CornerRadius="6">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Images/plus_icon.png"
                                                           Width="80"
                                                           Height="80"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Visibility="{Binding IsExcelCard, Converter={StaticResource BoolToVisibility}}">
                                            <Border BorderThickness="2" 
                                            Background="{StaticResource LightGreen}"
                                            CornerRadius="6">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Images/excel_icon.png"
                                                           Width="80"
                                                           Height="80"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Visibility="{Binding IsCreateCard, Converter={StaticResource InverseBoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="2*"/>
                                                <RowDefinition Height="2"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="1"/>
                                                    <ColumnDefinition Width="3*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15 0 25 0" Grid.Row="0" Grid.Column="0">
                                                    <TextBlock Text="{Binding Test.TestType.Name}" FontSize="20" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Test.IsArchive, Converter={StaticResource ArchiveTextConverter}}" FontSize="11" FontWeight="Bold"/>
                                                </StackPanel>

                                                <Border BorderBrush="Black" BorderThickness="2" Margin="0 10" Grid.Column="1"/>

                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 25 0" Grid.Row="0" Grid.Column="2">
                                                    <TextBlock Text="{Binding Test.Topic.Name}" FontSize="20" FontWeight="Bold"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
                                                        <TextBlock FontSize="13" Foreground="#666">
                                                            <Run Text="{Binding Test.PenaltyMax}"/>
                                                            <Run Text=" вопр. · "/>
                                                            <Run Text="{Binding Test.TimeLimitSecond}"/>
                                                            <Run Text=" сек. · "/>
                                                            <Run Text="{Binding Test.MaxNumPassing}"/>
                                                            <Run Text=" макс. попыток"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Grid.ColumnSpan="3">
                                                    <TextBlock Text="{Binding Test.Name}" FontSize="32"/>
                                                </StackPanel>

                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2" Grid.ColumnSpan="3">
                                                    <TextBlock Text="{Binding Test.Description}" FontSize="15" TextWrapping="Wrap" MaxWidth="360"/>
                                                </StackPanel>

                                            </Grid>

                                            <Border Grid.Row="1"
                                                    BorderBrush="{StaticResource MainSwamp}"
                                                    BorderThickness="2"/>

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                           Text="{Binding Test.DateOfCreating, StringFormat={}{0:dd.MM.yyyy}}"
                                                           VerticalAlignment="Bottom"   
                                                           FontSize="20" 
                                                           Margin="10 5 0 0"/>

                                                    <TextBlock Grid.Column="1"
                                                           Text="{Binding Test.CuratorCreate.Name}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Bottom"  
                                                           FontSize="20" 
                                                           Margin="0 5 10 0"
                                                           TextWrapping="Wrap"/>
                                                </Grid>

                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"  Grid.RowSpan="2"
                                                           Content="Опубликовать" VerticalAlignment="Center" FontSize="20" Grid.ColumnSpan="2" Margin="10 0 0 0"/>
                                                    <!--IsChecked="{Binding IsPublic}"-->


                                                    <Menu Grid.Column="1"
                                                          Width="50"
                                                          Height="50"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent" Margin="5">
                                                        <MenuItem Width="50" Height="50" Padding="-10">
                                                            <MenuItem.Header>
                                                                <Image Source="pack://application:,,,/Images/menu_icon.png"
                                                                       Width="50"
                                                                       Height="50"
                                                                       Stretch="Uniform"/>
                                                            </MenuItem.Header>
                                                            <MenuItem Header="Детализация публикации"/>
                                                            <MenuItem Header="Посмотреть прохождения"/>
                                                            <MenuItem Header="Архив" 
                                                                      Command="{Binding DataContext.ArchiveTestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                      CommandParameter="{Binding Test}"/>
                                                        </MenuItem>
                                                    </Menu>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!--<Grid Background="#80000000"
      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
      Panel.ZIndex="100">

                <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">

                    <ProgressBar Width="200"
                     Height="20"
                     IsIndeterminate="True"/>

                    <TextBlock Text="Загрузка..."
                   Foreground="White"
                   FontSize="16"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>-->
        </Grid>
    </Grid>
</UserControl>