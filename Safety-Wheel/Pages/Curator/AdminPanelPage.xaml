<Page x:Class="CozyTest.Pages.Curator.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.Pages.Curator"
      xmlns:conv="clr-namespace:CozyTest.Converters"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      mc:Ignorable="d" 
      d:DesignHeight="915" d:DesignWidth="1815"
      Title="AdminPanelPage"
      Margin="15">

    <Page.Resources>
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
        <conv:EnabledConverter x:Key="EnabledConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                </Grid.Resources>
                
                <TabControl Grid.Column="0" Grid.Row="0">
                    <TabItem Header="Пользователи" Tag="Users" MouseLeftButtonUp="TabItem_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton Width="110" Height="40" Margin="10" Content="Привязаны ко мне" IsChecked="{Binding BindIsChecked}"/>
                                <ToggleButton Width="90" Height="40" Margin="10" Content="Созданы мной" IsChecked="{Binding CreateIsChecked}"/>
                                <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="{Binding ActiveIsChecked}"/>
                                <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные" IsChecked="{Binding ArchiveIsChecked}"/>
                                <TextBox Width="270" Height="42" Margin="20 10" mah:TextBoxHelper.Watermark="Поиск по имени" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <Expander Header="Тестируемые" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Style="{StaticResource PaleButton}" Click="Button_SearchParticipant">
                                                <Image  Source="pack://application:,,,/Images/search_icon.png"/>
                                            </Button>
                                            <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddParticipant">
                                                <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                            </Button>
                                        </Grid>
                                        <DataGrid BorderThickness="3" ItemsSource="{Binding ParticipantsList}" SelectedItem="{Binding SelectedParticipant}" AutoGenerateColumns="False" IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                                <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                                                <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                                <DataGridTemplateColumn Header="В архиве">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Command="{Binding DataContext.ArchiveParticipantCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  CommandParameter="{Binding}"
                                                                  IsEnabled="False"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>

                                            <DataGrid.ContextMenu>
                                                <ContextMenu Height="Auto">
                                                    <MenuItem Click="Button_EditParticipant" Header="Редактировать"/>
                                                    <MenuItem Command="{Binding ArchiveParticipantCommand}" Header="В архив"/>
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                        </DataGrid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Кураторы" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold" Margin="0 10 0 0" Visibility="{Binding Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=Admin}">
                                    <StackPanel>
                                        <Grid>
                                            <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddCurator">
                                                <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                            </Button>
                                        </Grid>
                                        <DataGrid BorderThickness="3" ItemsSource="{Binding CuratorsList}" SelectedItem="{Binding SelectedCurator}" AutoGenerateColumns="False" IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                                <DataGridTemplateColumn Header="Админ">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsAdmin, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Command="{Binding DataContext.ArchiveCuratorCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  CommandParameter="{Binding}"
                                                                  IsEnabled="False"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="В архиве">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Command="{Binding DataContext.AdminStatusCuratorCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  CommandParameter="{Binding}"
                                                                  IsEnabled="False"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>

                                            <DataGrid.ContextMenu>
                                                <ContextMenu Height="Auto">
                                                    <MenuItem Click="Button_EditParticipant" Header="Редактировать"/>
                                                    <MenuItem Command="{Binding ArchiveCuratorCommand}" Header="В архив"/>
                                                    <MenuItem Command="{Binding AdminStatusCuratorCommand}" Header="Изменить статус админа"/>
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                        </DataGrid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Заявки" Tag="Requests" MouseLeftButtonUp="TabItem_Click" Visibility="{Binding Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=Admin}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="{Binding ActiveIsCheckedReq}" />
                                <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные" IsChecked="{Binding ArchiveIsCheckedReq}"/>
                                <TextBox Width="270" Height="42" Margin="20 10" mah:TextBoxHelper.Watermark="Поиск по имени" Text="{Binding SearchTextRequest, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel>
                                    <DataGrid BorderThickness="3" ItemsSource="{Binding RequestsList}" SelectedItem="{Binding SelectedRequests}" AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                            <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                            <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                            <DataGridTextColumn Binding="{Binding Status}" Header="Статус заявки" />
                                            <DataGridTextColumn Binding="{Binding DateTimeApplication}" Header="Время подачи" />
                                            <DataGridTextColumn Binding="{Binding ReviewerId}" Header="Кто рассмотрел ID" />
                                            <DataGridTextColumn Binding="{Binding Reviewer.Name}" Header="Заявку рассмотрел" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Группы" Tag="Groups" MouseLeftButtonUp="TabItem_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox Width="270" Height="42" Margin="0 10" mah:TextBoxHelper.Watermark="Поиск по названию" Text="{Binding SearchTextGroup, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddGroup">
                                            <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                        </Button>
                                    </Grid>
                                    
                                    <DataGrid BorderThickness="3" ItemsSource="{Binding GroupsList}" SelectedItem="{Binding SelectedGroup}" AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                            <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                            <DataGridTextColumn Binding="{Binding CuratorId}" Header="Создатель ID" />
                                            <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                        </DataGrid.Columns>

                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <ContextMenu.ToolTip>
                                                    <TextBlock>
                                                        <TextBlock Text="Удаление доступно только если в группе нет участников"/>
                                                    </TextBlock>
                                                </ContextMenu.ToolTip>
                                                <MenuItem Header="Редактировать"/>
                                                <MenuItem Header="Удалить" Command="{Binding DeleteGroupCommand}">
                                                    <MenuItem.IsEnabled>
                                                        <MultiBinding Converter="{StaticResource EnabledConverter}">
                                                            <Binding Path="SelectedGroup"/>
                                                        </MultiBinding>
                                                    </MenuItem.IsEnabled>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                    </DataGrid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid x:Name="GridUsersData1" Grid.Column="2"  Visibility="{Binding CuratorsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="108"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource MainText}" Text="{Binding SelectedCurator.Name, StringFormat='Данные, связанные с экзаменатором {0}'}"/>

                <StackPanel Grid.Row="1">
                    <Expander Header="Связанные тестируемые" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding ParticipantsForCuratorList}" AutoGenerateColumns="False" IsReadOnly="True"> <!--SelectedItem="{Binding SelectedParticipant}"--> 
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                    <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                    <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                                    <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                    <DataGridTemplateColumn Header="В архиве">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Command="{Binding DataContext.ArchiveParticipantCommand, 
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Связанные тесты" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold"  Margin="0 10 0 0">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding TestsForCuratorList}" SelectedItem="{Binding SelectedTest}" AutoGenerateColumns="False" IsReadOnly="True">
                                <!--SelectedItem="{Binding SelectedParticipant}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Topic.Name}" Header="Тема" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                    <DataGridTextColumn Binding="{Binding DateOfCreating}" Header="Дата создания" />
                                    <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                    <DataGridTextColumn Binding="{Binding MaxNumPassing}" Header="Макс. попыток" />
                                    <DataGridTemplateColumn Header="В архиве">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>

                                <DataGrid.ContextMenu>
                                    <ContextMenu Height="Auto">
                                        <MenuItem Command="{Binding ArchiveTestCommand}" Header="В архив"/>
                                        <MenuItem Click="Button_PublishTest" Header="Настройки публикации"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Связанные группы" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold" Margin="0 10 0 0">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding GroupsForCuratorList}" AutoGenerateColumns="False" IsReadOnly="True">
                                <!--SelectedItem="{Binding SelectedParticipant}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                    <DataGridTextColumn Binding="{Binding CuratorId}" Header="Создатель ID" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>

            <Grid x:Name="GridUsersData12" Grid.Column="2"  Visibility="{Binding ParticipantsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="108"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource MainText}" Text="{Binding SelectedParticipant.Name, StringFormat='Данные, связанные с пользователем {0}'}"/>

                <StackPanel Grid.Row="1">
                    <Expander Header="Состоит в группах" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding GroupsListCurrent}"  AutoGenerateColumns="False" IsReadOnly="True"><!--SelectedItem="{Binding SelectedParticipant}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                    <DataGridTextColumn Binding="{Binding CuratorId}" Header="Создатель ID" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Привязан к экзаменаторам" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold"  Margin="0 10 0 0">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding CuratorsListCurrent}"  AutoGenerateColumns="False" IsReadOnly="True"><!--SelectedItem="{Binding SelectedCurator}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                    <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                    <DataGridTemplateColumn Header="Админ">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsAdmin, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Command="{Binding DataContext.ArchiveCuratorCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           CommandParameter="{Binding}"
                                                           IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="В архиве">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Command="{Binding DataContext.AdminStatusCuratorCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           CommandParameter="{Binding}"
                                                           IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>

                                <DataGrid.ContextMenu>
                                    <ContextMenu Height="Auto">
                                        <MenuItem Click="Button_EditParticipant" Header="Редактировать"/>
                                        <MenuItem Command="{Binding ArchiveCuratorCommand}" Header="В архив"/>
                                        <MenuItem Command="{Binding AdminStatusCuratorCommand}" Header="Изменить статус админа"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
            
            <Grid x:Name="GridUsersData2" Grid.Column="2"  Visibility="{Binding RequestsVisibility}" Margin="70">
                <Grid.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}"/>
                    <Style TargetType="PasswordBox" BasedOn="{StaticResource ShellPasswordBox}"/>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="108"/>

                    <RowDefinition Height="80"/>
                    <RowDefinition Height="40"/>

                    <RowDefinition Height="80"/>
                    <RowDefinition Height="40"/>

                    <RowDefinition Height="80"/>
                    <RowDefinition Height="40"/>

                    <RowDefinition Height="160"/>
                    <RowDefinition Height="40"/>

                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SelectedRequests.Id, StringFormat='Заявка №{0}   '}" Style="{StaticResource MainText}"/>
                    <TextBlock Text="{Binding SelectedRequests.DateTimeApplication, StringFormat='от {0:dd.MM.yyyy}'}" Style="{StaticResource MainText}"/>
                </StackPanel>
                

                <TextBox Grid.Row="1" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Имя Фамилия" Text="{Binding Name}"/>
                <TextBox Grid.Row="3" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Логин" Text="{Binding Login}" IsEnabled="False"/>
                <TextBox Grid.Row="5" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Дата подачи заявления" Text="{Binding Date}" IsEnabled="False"/>

                <StackPanel Grid.Row="7">
                    <RadioButton Margin="0 10" Content="Закрепить за мной" TextElement.FontSize="24" IsChecked="{Binding BindMe}"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Margin="0 10" Content="Закрепить за " TextElement.FontSize="24" IsChecked="{Binding BindFor}"/>
                        <ComboBox Width="305" Style="{StaticResource UpMenuTestComboBox}" TextElement.FontSize="24" ItemsSource="{Binding CuratorsList}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <RadioButton Margin="0 10" Content="Не закреплять ни за кем" TextElement.FontSize="24" IsChecked="{Binding BindNone}"/>
                </StackPanel>
                
                <Grid Grid.Row="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Принять заявку" Command="{Binding AcceptRequestCommand}" Style="{StaticResource ShellDarkSwampButton}" Height="80" IsEnabled="{Binding AcceptEnabled}"/>
                    <Button Grid.Column="1" Content="Отклонить заявку" Command="{Binding RejectRequestCommand}" Style="{StaticResource ShellDarkSwampButton}" Height="80" IsEnabled="{Binding RejectEnabled}"/>
                </Grid>
            </Grid>

            <Grid x:Name="GridUsersData3" Grid.Column="2"  Visibility="{Binding GroupsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="108"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding SelectedGroup.Name, StringFormat='Данные, связанные с группой {0}'}" Style="{StaticResource MainText}"/>

                <StackPanel Grid.Row="1">
                    <Expander Header="Привязанные тестируемые" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="53*"/>
                                    <ColumnDefinition Width="95*"/>
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource PaleButton}" Grid.ColumnSpan="2"  Click="Button_BindUserForGroup">
                                    <Image  Source="pack://application:,,,/Images/search_icon.png"/>
                                </Button>
                            </Grid>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding ParticipantsForGroupList}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                    <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                    <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                                    <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                    <DataGridTemplateColumn Header="В архиве">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
