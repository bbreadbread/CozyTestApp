<Page x:Class="Safety_Wheel.Pages.Curator.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Safety_Wheel.Pages.Curator"
      xmlns:conv="clr-namespace:Safety_Wheel.Converters"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      mc:Ignorable="d" 
      d:DesignHeight="915" d:DesignWidth="1815"
      Title="AdminPanelPage"
      Margin="15">

    <Page.Resources>
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
    </Page.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid>
            <TabControl Grid.Column="0" Grid.Row="0">
                <TabItem Header="Пользователи" Tag="Users" MouseLeftButtonUp="TabItem_Click">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="True"/>
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные"/>
                            <ToggleButton Width="110" Height="40" Margin="10" Content="Привязаны к Вам"/>
                        </StackPanel>

                        <StackPanel>
                            <Expander Header="Тестируемые" IsExpanded="False" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource PaleButton}" Click="Button_SearchParticipant">
                                            <Image  Source="pack://application:,,,/Images/search_icon.png"/>
                                        </Button>
                                        <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddParticipant">
                                            <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                        </Button>
                                    </Grid>
                                    <DataGrid BorderThickness="0" ItemsSource="{Binding ParticipantsList}" SelectedItem="{Binding SelectedParticipant}" AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                            <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                            <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                            <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                                            <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                                            <DataGridCheckBoxColumn Binding="{Binding Path=IsArchive, Mode=OneWay}"
                                                                     EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                     ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                     Header="В архиве" />
                                        </DataGrid.Columns>
                                        
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Click="Button_CreateParticipant" Header="Редактировать"/>
                                                <MenuItem Click="Button_ArchiveParticipant" Header="В архив"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                    </DataGrid>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Кураторы" IsExpanded="False" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                                <StackPanel>
                                    <Grid>
                                        <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddCurator">
                                            <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                        </Button>
                                    </Grid>
                                    <DataGrid BorderThickness="0" ItemsSource="{Binding CuratorsList}" AutoGenerateColumns="False" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                            <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                            <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                            <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsAdmin, Mode=OneWay}"
                                                                      EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                      ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                      Header="Админ" />
                                            <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsArchive, Mode=OneWay}"
                                                                      EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                      ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                      Header="В архиве" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Заявки" Tag="Requests" MouseLeftButtonUp="TabItem_Click">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="True"/>
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные"/>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel>
                                <DataGrid BorderThickness="0" ItemsSource="{Binding ApplicationsList}" AutoGenerateColumns="False" IsReadOnly="True">
                                     <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                         <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                        <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                        <DataGridTextColumn Binding="{Binding Status}" Header="Статус заявки" />
                                        <DataGridTextColumn Binding="{Binding DateTimeApplication}" Header="Время подачи" />
                                        <DataGridTextColumn Binding="{Binding ReviewerId}" Header="Кто рассмотрел ID" />
                                        <DataGridTextColumn Binding="{Binding Reviewer.Name}" Header="Заявку рассмотрел" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Группы" Tag="Groups" MouseLeftButtonUp="TabItem_Click">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="True"/>
                            <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные"/>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddGroup">
                                        <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                                    </Button>
                                </Grid>
                                <DataGrid BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Title}" Header="ID" />
                                        <DataGridTextColumn Binding="{Binding Artist.Name}" Header="Наименование" />
                                        <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Описание" />
                                        <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Кол-во участников" />
                                        <DataGridCheckBoxColumn Binding="{Binding  Path=IsSelected, Mode=OneWay}"
                                                                 ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                                                 Header="В архиве" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <Grid x:Name="GridUsersData1" Grid.Column="2" Visibility="{Binding SelectedTab, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Users}">
            <Grid.RowDefinitions>
                <RowDefinition Height="108"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Style="{StaticResource MainText}" Text="{Binding SelectedParticipant.Name, StringFormat='Данные, связанные с пользователем {0}'}"/>

            <StackPanel Grid.Row="1">
                <Expander Header="Привязанные тестируемые" IsExpanded="False" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                    <StackPanel>
                        <DataGrid BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Title}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Artist.Name}" Header="ФИО" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Логин" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Создатель" />
                                <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=OneWay}"
                                             EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                             ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                             Header="В архиве" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Expander>

                <Expander Header="Привязанные тесты" IsExpanded="False" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                    <StackPanel>
                        <DataGrid BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Title}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Title}" Header="Тема" />
                                <DataGridTextColumn Binding="{Binding Artist.Name}" Header="Название" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Описание" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Дата создания" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Время" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Создатель" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Макс. попыток" />
                                <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=OneWay}"
                                              EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                              ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                              Header="Опубликован" />
                                <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=OneWay}"
                                              EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                              ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                              Header="В архиве" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridUsersData2" Grid.Column="2"  Visibility="{Binding SelectedTab, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Requests}">
            <Grid.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource ShellTextBox}"/>
                <Style TargetType="PasswordBox" BasedOn="{StaticResource ShellPasswordBox}"/>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="108"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="80"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="150"/>
                <RowDefinition Height="40"/>

                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Заявка №0" Style="{StaticResource MainText}"/>
            
            <TextBox Grid.Row="1" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Имя Фамилия"/>
            <TextBox Grid.Row="3" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Логин"/>
            <TextBox Grid.Row="5" Margin="0 0 0 0" mah:TextBoxHelper.Watermark="Дата подачи заявления" IsEnabled="False"/>

            <StackPanel Grid.Row="7">
                <RadioButton Margin="0 10" Content="Закрепить за мной" TextElement.FontSize="24"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Margin="0 10" Content="Закрепить за " TextElement.FontSize="24"/>
                    <ComboBox Width="305" Style="{StaticResource UpMenuTestComboBox}" TextElement.FontSize="24"/>
                </StackPanel>
                <RadioButton Margin="0 10" Content="Не закреплять ни за кем" TextElement.FontSize="24"/>
            </StackPanel>
            <Grid Grid.Row="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Принять заявку" Style="{StaticResource ShellDarkSwampButton}" Height="80"/>
                <Button Grid.Column="1" Content="Отклонить заявку" Style="{StaticResource ShellDarkSwampButton}" Height="80"/>
            </Grid>
        </Grid>

        <Grid x:Name="GridUsersData3" Grid.Column="2" Visibility="{Binding SelectedTab, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Groups}">
            <Grid.RowDefinitions>
                <RowDefinition Height="108"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Данные, связанные с группой" Style="{StaticResource MainText}"/>

            <StackPanel Grid.Row="1">
                <Expander Header="Привязанные тестируемые" IsExpanded="False" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1" Style="{StaticResource PaleButton}">
                                <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                            </Button>
                        </Grid>
                        <DataGrid BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Title}" Header="ID" />
                                <DataGridTextColumn Binding="{Binding Artist.Name}" Header="ФИО" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Логин" />
                                <DataGridTextColumn Binding="{Binding Genre.Name}" Header="Создатель" />
                                <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=OneWay}"
                                     EditingElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                     ElementStyle="{DynamicResource MetroDataGridCheckBox}"
                                     Header="В архиве" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
