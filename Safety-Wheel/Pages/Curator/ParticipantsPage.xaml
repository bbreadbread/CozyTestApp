<UserControl x:Class="CozyTest.Pages.Curator.ParticipantsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CozyTest.Pages.Curator"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
           mc:Ignorable="d" 
           d:DesignHeight="915" d:DesignWidth="1815">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <ToggleButton Width="110" Height="40" Margin="10" Content="Привязаны ко мне" IsChecked="{Binding BindIsChecked}"/>
                <ToggleButton Width="90" Height="40" Margin="10" Content="Созданы мной" IsChecked="{Binding CreateIsChecked}"/>
                <ToggleButton Width="90" Height="40" Margin="10" Content="Активные" IsChecked="{Binding ActiveIsChecked}"/>
                <ToggleButton Width="90" Height="40" Margin="10" Content="Архивные" IsChecked="{Binding ArchiveIsChecked}"/>
                <TextBox Width="270" Height="42" Margin="20 10" mah:TextBoxHelper.Watermark="Поиск по имени" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <Expander Header="Тестируемые" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource PaleButton}" Click="Button_SearchParticipant">
                            <Image  Source="pack://application:,,,/Images/search_icon.png"/>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource PaleButton}" Click="Button_AddParticipant">
                            <Image  Source="pack://application:,,,/Images/plus_icon.png"/>
                        </Button>
                    </Grid>
                    <DataGrid BorderThickness="3" ItemsSource="{Binding ParticipantsList}" SelectedItem="{Binding SelectedParticipant}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                            <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                            <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                            <DataGridTextColumn Binding="{Binding CuratorCreateId}" Header="ID создателя" />
                            <DataGridTextColumn Binding="{Binding CuratorCreate.Name}" Header="Создатель" />
                            <DataGridTemplateColumn Header="В архиве">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                           Command="{Binding DataContext.ArchiveParticipantCommand, 
                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}"
                                           IsEnabled="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <DataGrid.ContextMenu>
                            <ContextMenu Height="Auto">
                                <MenuItem Click="Button_EditParticipant" Header="Редактировать"/>
                                <MenuItem Command="{Binding ArchiveParticipantCommand}" Header="В архив"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </StackPanel>
            </Expander>
        </StackPanel>
        
        <StackPanel Grid.Column="1">
            <Grid x:Name="GridUsersData12" Grid.Column="2"  Visibility="{Binding ParticipantsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="108"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource MainText}" Text="{Binding SelectedParticipant.Name, StringFormat='Данные, связанные с пользователем {0}'}"/>

                <StackPanel Grid.Row="1">
                    <Expander Header="Состоит в группах" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding GroupsListCurrent}"  AutoGenerateColumns="False" IsReadOnly="True">
                                <!--SelectedItem="{Binding SelectedParticipant}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="Название" />
                                    <DataGridTextColumn Binding="{Binding CuratorId}" Header="Создатель ID" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Привязан к экзаменаторам" IsExpanded="True" Background="{StaticResource MainSwamp}" Foreground="White" FontWeight="Bold"  Margin="0 10 0 0">
                        <StackPanel>
                            <DataGrid BorderThickness="3" ItemsSource="{Binding CuratorsListCurrent}"  AutoGenerateColumns="False" IsReadOnly="True">
                                <!--SelectedItem="{Binding SelectedCurator}"-->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                                    <DataGridTextColumn Binding="{Binding Name}" Header="ФИО" />
                                    <DataGridTextColumn Binding="{Binding Login}" Header="Логин" />
                                    <DataGridTemplateColumn Header="Админ">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsAdmin, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                               Command="{Binding DataContext.ArchiveCuratorCommand, 
                                               RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="В архиве">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsArchive, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                               Command="{Binding DataContext.AdminStatusCuratorCommand, 
                                               RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               IsEnabled="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>

                                <DataGrid.ContextMenu>
                                    <ContextMenu Height="Auto">
                                        <MenuItem Click="Button_EditParticipant" Header="Редактировать"/>
                                        <MenuItem Command="{Binding ArchiveCuratorCommand}" Header="В архив"/>
                                        <MenuItem Command="{Binding AdminStatusCuratorCommand}" Header="Изменить статус админа"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
